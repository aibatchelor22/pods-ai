{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^tests/test_run_inference\\.py$/"
      ],
      "matchStrings": [
        "PODSAI_TEST_MODEL_REVISION = \"(?<currentValue>[a-f0-9]{7,64})\""
      ],
      "depNameTemplate": "https://huggingface.co/davethaler/whale-call-detector",
      "datasourceTemplate": "git-refs",
      "versioningTemplate": "git"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^src/run_inference\\.py$/",
        "/^src/compare_models\\.py$/",
        "/^src/add_samples\\.py$/",
        "/^src/LiveInferenceOrchestrator\\.py$/"
      ],
      "matchStrings": [
        "PODSAI_MODEL_REVISION = \"(?<currentValue>[a-f0-9]{7,64})\"",
        "DEFAULT_MODEL_REVISION = \"(?<currentValue>[a-f0-9]{7,64})\""
      ],
      "depNameTemplate": "https://huggingface.co/davethaler/whale-call-detector",
      "datasourceTemplate": "git-refs",
      "versioningTemplate": "git"
    }
  ],
  "packageRules": [
    {
      "description": "Track pinned PODS-AI model updates in the dependency dashboard issue.",
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "https://huggingface.co/davethaler/whale-call-detector"
      ],
      "dependencyDashboardApproval": true
    }
  ]
}
